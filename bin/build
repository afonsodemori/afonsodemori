#!/bin/bash

# install assets
rm -rf dist && mkdir dist
cp -rv resources/* dist/

# generate pages (migrate to java)
bin/generate-pages

# compile classes
rm -rf out && mkdir out
javac -d out src/dev/afonso/*.java

# import resumes and generate shortcuts
java -cp out dev.afonso.PageGenerator
java -cp out dev.afonso.ResumesImporter
java -cp out dev.afonso.ShortcutsGenerator

# tag the build version
printf "<h1>OK</h1>\n" > dist/health-check.html
printf "<address>Last build: $(date)</address>\n" >> dist/health-check.html
