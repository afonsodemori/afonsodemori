#!/usr/bin/env php
<?php

// TODO: Using composer is failing in GitHub. Don't know why...
require __DIR__ . '/../src/Helper/CliHelper.php';
require __DIR__ . '/../src/Model/Page/RedirectionPage.php';
require __DIR__ . '/../src/Model/ShortcutUrl.php';
require __DIR__ . '/../src/Model/Url.php';

use App\Helper\CliHelper;
use App\Model\Page\RedirectionPage;
use App\Model\ShortcutUrl;
use App\Model\Url;

$startTime = microtime(true);

function generatePage(string $urlString): RedirectionPage
{
    $url = new Url($urlString);

    $iconBaseUrl = 'https://afonso.dev/assets/images/icons';
    $basePath = dirname(__DIR__) . '/resources/assets/images/icons';
    $fileName = str_replace('.', '-', $url->getHost(true));
    foreach (['png', 'jpg'] as $extension) {
        if (file_exists("$basePath/$fileName.$extension")) {
            $icon = "$iconBaseUrl/$fileName.$extension";
            break;
        }
    }

    if (!isset($icon)) {
        $icon = "$iconBaseUrl/default.jpg";
    }

    if (strpos($url->getHost(true), "afonso.dev") !== false) {
        $title = "afonso.dev // Redirection";
    } else {
        $title = "afonso.dev // Go to {$url->getHost(true)}";
    }
    $description = "Redirects to {$url->__toString()}";
    $printableUrl = "{$url->getScheme()}://<strong>{$url->getHost(true)}</strong>{$url->getFullPath()}";

    return new RedirectionPage(
        $title,
        $description,
        $urlString,
        $icon,
        $printableUrl
    );
}

function render(RedirectionPage $page): string
{
    ob_start();
    require __DIR__ . '/../templates/redirection.php';
    return ob_get_clean();
}

$appDir = dirname(__DIR__);
$tmpDir = sys_get_temp_dir();

$feedUrl = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vRny4h8y8u_z3FDv3JaLt7PZuB0zy1VzX4ep7E9gD-tihrZGpeNT6AUS33B8FM5xpN22WRz5qeQaQUs/pub?gid=2039462908&single=true&output=csv';
$feedPath = sys_get_temp_dir() . '/shortener-urls.csv';

$curl = curl_init();
echo "Fetching `$feedUrl`... ";
curl_setopt_array($curl, array(
    CURLOPT_URL => $feedUrl,
    CURLOPT_RETURNTRANSFER => true,
    CURLOPT_ENCODING => '',
    CURLOPT_MAXREDIRS => 10,
    CURLOPT_TIMEOUT => 10,
    CURLOPT_FOLLOWLOCATION => true,
    CURLOPT_HTTP_VERSION => CURL_HTTP_VERSION_1_1,
    CURLOPT_CUSTOMREQUEST => 'GET',
));

file_put_contents($feedPath, curl_exec($curl));
curl_close($curl);

echo "OK\n";

$handle = fopen($feedPath, 'rb');
$headers = fgetcsv($handle, 1000);

$filepath = __DIR__ . "/../dist/_redirects";
file_put_contents($filepath, "");
while (($data = fgetcsv($handle, 1000)) !== false) {
    $shortcutUrl = ShortcutUrl::fromCsvRow($data);

    foreach ($shortcutUrl->getShortcuts() as $shortcut) {
        echo "Generating /$shortcut...\n";
        file_put_contents($filepath, "/$shortcut {$shortcutUrl->getLongUrl()} 301\n", FILE_APPEND);
        $shortcutPath = "$appDir/dist/$shortcut.html";
        CliHelper::writeFile($shortcutPath, render(generatePage($shortcutUrl->getLongUrl())));
    }
}

$spentTime = number_format(microtime(true) - $startTime, 2);

echo "\nDone! In $spentTime seconds\n";
