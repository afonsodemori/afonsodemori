#!/usr/bin/env php
<?php

// TODO: Using composer is failing in GitHub. Don't know why...
require __DIR__ . '/../src/Model/HtmlPage.php';
require __DIR__ . '/../src/Helper/CliHelper.php';

use App\Helper\CliHelper as Cli;
use App\Model\HtmlPage;

$pages = [
    new HtmlPage('home', '/'),
    new HtmlPage('contact', '/contact'),
    new HtmlPage('cv', '/cv'),
    new HtmlPage('courses', '/courses'),
];

foreach (HtmlPage::LANGUAGES as $lang) {
    Cli::log("Creating pages for lang '$lang'...");
    $locale = $lang;
    foreach ($pages as $page) {
        Cli::log("=> Page: {$page->getId()}");
        $page->setLang($lang);

        $translations = $page->getTranslations();
        Cli::log("=> Translations: $translations");

        $template = $page->getTemplate();
        Cli::log("=> Template: $template");

        ob_start();
        require $translations;
        require $template;
        $html = ob_get_clean();

        Cli::log("Output => {$page->getOutputPath()}");

        Cli::writeFile($page->getOutputPath(), $html);
        Cli::ln();
    }
    Cli::ln();
}
