#!/usr/bin/env php
<?php

// TODO: Using composer is failing in GitHub. Don't know why...
require __DIR__ . '/../src/Helper/CliHelper.php';

use App\Helper\CliHelper;

$startTime = microtime(true);

$appDir = dirname(__DIR__);
$filesDir = "$appDir/_site/docs";

$formats = [
    'pdf',
    'docx',
    'txt',
    'odt',
];

$fileHashes = [
    'en' => '1aYKfrRKX0YHVZukZvMGe3cXTOIY648ZXwF3iXTGQF34',
    'es' => '1TT9BpFpy6QBs1sygecTuPAHD8iPMPII1y3Rw7rNuj74',
    'pt' => '1hWho1MfmHPZIXEARbHaZJydXULzVoTqSnMi0Z64dOq8',
];

$baseUrl = 'https://docs.google.com/document/export?id=%s&format=%s';

$handles = [];
$mh = curl_multi_init();
foreach ($fileHashes as $lang => $fileId) {
    foreach ($formats as $format) {
        $url = sprintf($baseUrl, $fileId, $format);
        echo "Preparing $url...\n";

        $ch = curl_init($url);
        curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
        curl_setopt($ch, CURLOPT_FOLLOWLOCATION, true);
        curl_setopt($ch, CURLOPT_MAXREDIRS, 1);

        $handles["$lang-$format"] = $ch;
        curl_multi_add_handle($mh, $ch);
    }
}

echo "\nGetting files from Google...";
do {
    $status = curl_multi_exec($mh, $active);
    if ($active) {
        curl_multi_select($mh);
    }
} while ($active && $status === CURLM_OK);

echo " [ OK ]\n\n";

foreach ($handles as $handle) {
    curl_multi_remove_handle($mh, $handle);
}

curl_multi_close($mh);

foreach ($handles as $key => $handle) {
    [$lang, $format] = explode('-', $key);
    $fileContent = curl_multi_getcontent($handle);

    $filePath = "$filesDir/cv-$lang-afonso_de_mori.$format";
    CliHelper::writeFile($filePath, $fileContent);
}

$spentTime = number_format(microtime(true) - $startTime, 2);

echo "\nDone! In $spentTime seconds\n";
